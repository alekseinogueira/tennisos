# 55TC TennisOS — environment variables (copy to .env and fill in real values)
# .env is gitignored; NEVER commit real keys. This file holds placeholders only.

# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings → API → anon public).
# Safe for the browser bundle. The service-role key NEVER goes here or to Vercel —
# it lives only as a Supabase Edge Function secret.
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Resend API key — Supabase Edge Function secret ONLY (server-side).
# NEVER a VITE_ var, never in the browser bundle, never committed.
RESEND_API_KEY=your_resend_api_key_here
